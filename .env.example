# Runtime
ENVIRONMENT=production
LOG_LEVEL=INFO
PORT=8080
DATA_DIR=/data

# CORS - set to your deployed Railway URL in production
ALLOWED_ORIGIN=https://your-app.up.railway.app

# First admin bootstrap
# In production, the app will NOT create an insecure default admin unless you explicitly allow it.
INITIAL_ADMIN_NAME=School Admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change_this_immediately
ALLOW_DEFAULT_ADMIN=false

# Safety switch for legacy/destructive schema repair
# Keep this false in production unless you have a backup and intentionally want a one-time repair.
ALLOW_DESTRUCTIVE_MIGRATIONS=false

# Email (SMTP) - optional, for notifications
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
SMTP_FROM=noreply@gislschools.com
APP_URL=https://your-app.up.railway.app

# Paystack online payments
PAYSTACK_PUBLIC_KEY=your_paystack_public_key
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_CALLBACK_URL=https://your-app.up.railway.app/

# WhatsApp / SMS notifications
WHATSAPP_PROVIDER=termii
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER=GISL Schools
TERMII_SMS_ENDPOINT=https://api.ng.termii.com/api/sms/send
TERMII_WHATSAPP_ENDPOINT=

# Optional Meta WhatsApp Cloud API fallback
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
